{
  "functions": {
    "api/chat-agent.js": {
      "maxDuration": 30
    },
    "api/pdf-parser.js": {
      "maxDuration": 30
    },
    "api/setup-db.js": {
      "maxDuration": 10
    },
    "api/menu-analyzer.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}